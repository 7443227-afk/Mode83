BADGE83_HOST=127.0.0.1
BADGE83_PORT=8000

# Public URL used inside issued badges / QR codes.
BADGE83_BASE_URL=https://mode83.ddns.net
BADGE83_PUBLIC_SCHEME=https
BADGE83_PUBLIC_HOST=mode83.ddns.net
BADGE83_PUBLIC_PORT=443

# Firewall management is explicit and disabled by default.
# When set to true, badge83.sh start/stop can open/close only 80 and 443.
BADGE83_ENABLE_FIREWALL_MANAGEMENT=false
BADGE83_PUBLIC_HTTP_PORT=80
BADGE83_PUBLIC_HTTPS_PORT=443

BADGE83_SEARCH_PEPPER=badge83-dev-search-pepper

# Nginx auth_request login page credentials.
# Change these values before production use.
BADGE83_AUTH_USERNAME=admin83
BADGE83_AUTH_PASSWORD=admin83!@!admin83
BADGE83_AUTH_SECRET=badge83-change-this-secret