# Ignore environment file containing secrets
badge83.env
.env
.env.*
!.env.docker.example
!.env.production.example

# Docker runtime data mounted into /app/data
runtime-data/
docker/nginx/certs/*
!docker/nginx/certs/.gitkeep

# Ignore logs
*.log

# Ignore Python bytecode
__pycache/
*.py[cod]

# Ignore pytest cache
.pytest_cache/

# Ignore IDE files
.vscode/
.idea/
*.swp
*~badge83.env
