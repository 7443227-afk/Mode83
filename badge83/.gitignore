# Ignore environment file containing secrets
badge83.env
.env
.env.*
!.env.docker.example
!.env.production.example

# Docker runtime data mounted into /app/data
runtime-data/
docker/nginx/certs/*
!docker/nginx/certs/.gitkeep

# Generated Badge83 runtime data
data/issued/
data/baked/
data/registry.db
data/*.sqlite3
data/test-baked.png

# Ignore logs
*.log

# Ignore Python bytecode
__pycache/
*.py[cod]

# Ignore pytest cache
.pytest_cache/

# Ignore local virtualenv
.venv/

# Ignore IDE files
.vscode/
.idea/
Mode83.code-workspace
*.swp
*~badge83.env
