# Badge83 Docker local/demo configuration.
# Copy this file to .env before running Docker Compose:
#   cp .env.docker.example .env

BADGE83_ENV=development

# Internal app listen values inside the container.
BADGE83_HOST=0.0.0.0
BADGE83_PORT=8000

# Host port exposed by docker-compose.yml.
BADGE83_BIND_PORT=8000

# Public URL embedded into issued badges and QR codes.
BADGE83_BASE_URL=http://localhost:8000

# SQLite registry stored in the persistent bind mount ./runtime-data.
BADGE83_REGISTRY_DB=/app/data/registry.db

# Development/demo credentials. Change before real use.
BADGE83_AUTH_USERNAME=admin83
BADGE83_AUTH_PASSWORD=change-me-password
BADGE83_AUTH_SECRET=change-me-auth-secret
BADGE83_SEARCH_PEPPER=change-me-search-pepper

# Privacy/RGPD: false par défaut pour ne pas intégrer l'email complet dans
# l'assertion JSON publique ni dans le PNG baked. Passer explicitement à true
# uniquement si MODE83 accepte cette exposition dans le badge remis.
BADGE83_EMBED_ADMIN_RECIPIENT=false

# Upload limits.
BADGE83_MAX_PNG_UPLOAD_BYTES=52428800
BADGE83_MAX_CSV_UPLOAD_BYTES=10485760
BADGE83_MAX_IMAGE_PIXELS=50000000